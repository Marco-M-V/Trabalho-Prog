// ============================================================
// Funções auxiliares para trabalhar com strings
// ============================================================

int comparar_strings(char *s1, char *s2) {
    while (*s1 && *s2) {
        if (*s1 != *s2) return 0;
        s1++;
        s2++;
    }
    return (*s1 == '\0' && *s2 == '\0');
}

void copiar_string(char *destino, char *origem) {
    while (*origem) {
        *destino = *origem;
        destino++;
        origem++;
    }
    *destino = '\0';
}

int contar_caracteres(char *str) {
    int contador = 0;
    while (*str++) contador++;
    return contador;
}

// ============================================================
// Ordenação: Odd-Even Sort
// ============================================================

void ordenar_elementos(int *arr, int tamanho) {
    int ordenado = 0;
    while (!ordenado) {
        ordenado = 1;
        for (int i = 1; i < tamanho - 1; i += 2) {
            if (arr[i] > arr[i + 1]) {
                int temp = arr[i];
                arr[i] = arr[i + 1];
                arr[i + 1] = temp;
                ordenado = 0;
            }
        }
        for (int i = 0; i < tamanho - 1; i += 2) {
            if (arr[i] > arr[i + 1]) {
                int temp = arr[i];
                arr[i] = arr[i + 1];
                arr[i + 1] = temp;
                ordenado = 0;
            }
        }
    }
}

// ============================================================
// Cores ANSI
// ============================================================

#define VERMELHO "\033[1;31m"
#define VERDE    "\033[1;32m"
#define AZUL     "\033[1;34m"
#define AMARELO  "\033[1;33m"
#define RESET    "\033[0m"

// ============================================================
// Utilitário: leitura segura de inteiro dentro de um intervalo
// ============================================================

int ler_inteiro(int minimo, int maximo) {
    int valor;
    while (1) {
        if (scanf("%d", &valor) == 1) {
            while (getchar() != '\n');
            if (valor >= minimo && valor <= maximo) return valor;
        } else {
            while (getchar() != '\n');
        }
        printf("Opção inválida. Digite um número entre %d e %d: ", minimo, maximo);
    }
}

// ============================================================
// Quiz de Engenharia
// ============================================================

void quiz_engenharia() {
    struct Pergunta {
        char pergunta[150];
        char opcoes[4][60];
        int  resposta_correta;
    };

    struct Pergunta questoes[5] = {
        {
            "Que tipo de linguagem está sendo usada?",
            {"Java", "Python", "C", "Ruby"},
            2
        },
        {
            "O que significa CPU?",
            {
                "Unidade Central de Processamento",
                "Unidade de Processamento de Computadores",
                "Processador Central de Unidade",
                "Unidade Pessoal de Computador"
            },
            0
        },
        {
            "Qual NÃO é um tipo de dado em C?",
            {"int", "float", "string", "double"},
            2
        },
        {
            "Qual protocolo é utilizado para sites?",
            {"FTP", "HTTP", "SMTP", "UDP"},
            1
        },
        {
            "O que é um algoritmo?",
            {"Dispositivo de hardware", "Linguagem de programação", "Conjunto de instruções", "Sistema operacional"},
            2
        }
    };

    int pontos = 0;
    printf(AMARELO "\n=== QUIZ DE ENGENHARIA ===\n" RESET);

    for (int i = 0; i < 5; i++) {
        printf("\nPergunta %d: %s\n", i + 1, questoes[i].pergunta);
        for (int j = 0; j < 4; j++) {
            printf("  %d) %s\n", j + 1, questoes[i].opcoes[j]);
        }

        printf("Sua resposta (1-4): ");
        int resposta = ler_inteiro(1, 4);

        if (resposta - 1 == questoes[i].resposta_correta) {
            printf(VERDE "Resposta correta!\n" RESET);
            pontos++;
        } else {
            printf(VERMELHO "Errado! A resposta certa é: %d) %s\n" RESET,
                   questoes[i].resposta_correta + 1,
                   questoes[i].opcoes[questoes[i].resposta_correta]);
        }
    }

    printf(AMARELO "\nSua pontuação final: %d/5\n" RESET, pontos);

    if      (pontos == 5) printf(VERDE  "Excelente! Pontuação perfeita!\n" RESET);
    else if (pontos >= 3) printf(VERDE  "Bom trabalho!\n" RESET);
    else                  printf(VERMELHO "Continue estudando!\n" RESET);
}

// ============================================================
// Roletão de Caixas
// ============================================================

void roleta_caixas() {
    const char jogadores[7][20] = {"John", "Mary", "Carl", "Anna", "Peter", "Sophie", "Mike"};

    printf(AMARELO "\n=== ROLETAO DE CAIXAS ===\n" RESET);

    printf("\nEscolha o Jogador 1:\n");
    for (int i = 0; i < 7; i++) printf("  %d. %s\n", i + 1, jogadores[i]);
    printf("Jogador 1 (1-7): ");
    int jogador1 = ler_inteiro(1, 7);

    printf("\nEscolha o Jogador 2:\n");
    for (int i = 0; i < 7; i++) printf("  %d. %s\n", i + 1, jogadores[i]);
    printf("Jogador 2 (1-7): ");
    int jogador2 = ler_inteiro(1, 7);

    // Geração determinística sem rand()
    int semente = (jogador1 + jogador2) * 1000;
    int premio  = (semente % 5) + 1;
    int perigo  = (semente % 4) + 1;
    if (perigo >= premio) perigo++;

    int vez = semente % 2;
    printf(VERDE "\n%s começa!\n" RESET, jogadores[vez ? jogador2 - 1 : jogador1 - 1]);

    while (1) {
        const char *nome_atual = jogadores[vez ? jogador2 - 1 : jogador1 - 1];
        printf("\n%s, escolha uma caixa (1-5): ", nome_atual);
        int escolha = ler_inteiro(1, 5);

        if (escolha == premio) {
            printf(VERDE "PARABÉNS, %s! Você encontrou o prêmio!\n" RESET, nome_atual);
            break;
        } else if (escolha == perigo) {
            printf(VERMELHO "PERDEU, %s! Caixa amaldiçoada!\n" RESET, nome_atual);
            break;
        } else {
            printf("Caixa vazia. Vez do próximo jogador!\n");
            vez = !vez;
        }
    }
}

// ============================================================
// Batalha de Cavaleiros
// ============================================================

void batalha_cavaleiros() {
    typedef struct {
        char nome[20];
        int  cavaleiros[2];
    } Jogador;

    printf(AMARELO "\n=== BATALHA DE CAVALEIROS ===\n" RESET);

    Jogador j1, j2;

    printf("Nome do Jogador 1: ");
    fgets(j1.nome, sizeof(j1.nome), stdin);
    j1.nome[contar_caracteres(j1.nome) - 1] = '\0';

    printf("Nome do Jogador 2: ");
    fgets(j2.nome, sizeof(j2.nome), stdin);
    j2.nome[contar_caracteres(j2.nome) - 1] = '\0';

    j1.cavaleiros[0] = j1.cavaleiros[1] = 10;
    j2.cavaleiros[0] = j2.cavaleiros[1] = 10;

    int turno = 0;

    while (1) {
        Jogador *atual    = turno ? &j2 : &j1;
        Jogador *oponente = turno ? &j1 : &j2;

        printf(AZUL "\n--- Turno de %s ---\n" RESET, atual->nome);
        printf("  Seus cavaleiros  : [1] %d aura | [2] %d aura\n",
               atual->cavaleiros[0], atual->cavaleiros[1]);
        printf("  Cavaleiros inimigos: [1] %d aura | [2] %d aura\n",
               oponente->cavaleiros[0], oponente->cavaleiros[1]);

        printf("\n  1. Atacar\n  2. Transferir aura\n  3. Meditar\n");
        printf("Escolha (1-3): ");
        int acao = ler_inteiro(1, 3);

        if (acao == 1) {
            printf("Cavaleiro atacante (1-2): ");
            int atacante = ler_inteiro(1, 2);
            printf("Cavaleiro defensor (1-2): ");
            int defensor = ler_inteiro(1, 2);

            if (atual->cavaleiros[atacante - 1] <= 0) {
                printf(VERMELHO "Esse cavaleiro foi derrotado e não pode atacar!\n" RESET);
            } else {
                int dano = (atacante + defensor) % 3 + 2;
                oponente->cavaleiros[defensor - 1] -= dano;
                printf(VERMELHO "%d de dano causado ao cavaleiro %d de %s!\n" RESET,
                       dano, defensor, oponente->nome);

                if (oponente->cavaleiros[defensor - 1] <= 0) {
                    oponente->cavaleiros[defensor - 1] = 0;
                    printf(VERMELHO "Cavaleiro %d de %s foi derrotado!\n" RESET,
                           defensor, oponente->nome);
                }
            }

        } else if (acao == 2) {
            printf("Transferir de (1-2): ");
            int origem = ler_inteiro(1, 2);
            printf("Para (1-2): ");
            int destino = ler_inteiro(1, 2);

            if (origem == destino) {
                printf(VERMELHO "Origem e destino não podem ser o mesmo cavaleiro!\n" RESET);
            } else if (atual->cavaleiros[origem - 1] <= 1) {
                printf(VERMELHO "Aura insuficiente para transferir!\n" RESET);
            } else {
                int quantidade = atual->cavaleiros[origem - 1] / 2;
                atual->cavaleiros[origem - 1] -= quantidade;
                atual->cavaleiros[destino - 1] += quantidade;
                printf(VERDE "%d de aura transferida do cavaleiro %d para o cavaleiro %d!\n" RESET,
                       quantidade, origem, destino);
            }

        } else if (acao == 3) {
            printf("Cavaleiro para meditar (1-2): ");
            int cavaleiro = ler_inteiro(1, 2);

            int recuperacao = (cavaleiro + turno) % 2 + 3;
            atual->cavaleiros[cavaleiro - 1] += recuperacao;
            printf(AMARELO "Cavaleiro %d recuperou %d de aura!\n" RESET,
                   cavaleiro, recuperacao);
        }

        if (oponente->cavaleiros[0] <= 0 && oponente->cavaleiros[1] <= 0) {
            printf(VERDE "\n*** %s VENCEU A BATALHA! ***\n" RESET, atual->nome);
            break;
        }

        turno = !turno;
    }
}

