// ============================================================
// Funcoes auxiliares para trabalhar com strings
// ============================================================

int comparar_strings(char *s1, char *s2) {
    while (*s1 && *s2) {
        if (*s1 != *s2) return 0;
        s1++;
        s2++;
    }
    return (*s1 == '\0' && *s2 == '\0');
}

void copiar_string(char *destino, char *origem) {
    while (*origem) {
        *destino = *origem;
        destino++;
        origem++;
    }
    *destino = '\0';
}

int contar_caracteres(char *str) {
    int contador = 0;
    while (*str++) contador++;
    return contador;
}

// ============================================================
// Ordenacao: Odd-Even Sort
// ============================================================

void ordenar_elementos(int *arr, int tamanho) {
    int ordenado = 0;
    while (!ordenado) {
        ordenado = 1;
        for (int i = 1; i < tamanho - 1; i += 2) {
            if (arr[i] > arr[i + 1]) {
                int temp = arr[i];
                arr[i] = arr[i + 1];
                arr[i + 1] = temp;
                ordenado = 0;
            }
        }
        for (int i = 0; i < tamanho - 1; i += 2) {
            if (arr[i] > arr[i + 1]) {
                int temp = arr[i];
                arr[i] = arr[i + 1];
                arr[i + 1] = temp;
                ordenado = 0;
            }
        }
    }
}

// ============================================================
// Cores ANSI
// ============================================================

#define VERMELHO "\033[1;31m"
#define VERDE    "\033[1;32m"
#define AZUL     "\033[1;34m"
#define AMARELO  "\033[1;33m"
#define RESET    "\033[0m"

// ============================================================
// Utilitario: leitura segura de inteiro dentro de um intervalo
// ============================================================

int ler_inteiro(int minimo, int maximo) {
    int valor;
    while (1) {
        if (scanf("%d", &valor) == 1) {
            while (getchar() != '\n');
            if (valor >= minimo && valor <= maximo) return valor;
        } else {
            while (getchar() != '\n');
        }
        printf("Opcao invalida. Digite um numero entre %d e %d: ", minimo, maximo);
    }
}

// ============================================================
// Quiz de Engenharia
// ============================================================

#define TOTAL_QUESTOES      15
#define QUESTOES_POR_RODADA  8

void quiz_engenharia() {
    struct Pergunta {
        char pergunta[200];
        char opcoes[4][80];
        int  resposta_correta;
    };

    struct Pergunta banco[TOTAL_QUESTOES] = {
        {
            "Que tipo de linguagem esta sendo usada neste programa?",
            {"Java", "Python", "C", "Ruby"}, 2
        },
        {
            "O que significa CPU?",
            {"Unidade Central de Processamento",
             "Unidade de Processamento de Computadores",
             "Processador Central de Unidade",
             "Unidade Pessoal de Computador"}, 0
        },
        {
            "Qual NAO e um tipo de dado primitivo em C?",
            {"int", "float", "string", "double"}, 2
        },
        {
            "Qual protocolo e utilizado para acessar sites na web?",
            {"FTP", "HTTP", "SMTP", "UDP"}, 1
        },
        {
            "O que e um algoritmo?",
            {"Dispositivo de hardware",
             "Linguagem de programacao",
             "Conjunto ordenado de instrucoes",
             "Sistema operacional"}, 2
        },
        {
            "Qual estrutura de dados segue o principio FIFO?",
            {"Pilha", "Fila", "Arvore", "Grafo"}, 1
        },
        {
            "O que significa RAM?",
            {"Memoria de Acesso Aleatorio",
             "Modulo de Acesso Rapido",
             "Memoria de Armazenamento Remoto",
             "Registro de Acesso a Maquina"}, 0
        },
        {
            "Qual operador acessa membros de um ponteiro para struct em C?",
            {".", "::", "->", ":"}, 2
        },
        {
            "O que e um compilador?",
            {"Hardware que executa programas",
             "Programa que traduz codigo-fonte em executavel",
             "Sistema operacional especializado",
             "Tipo de banco de dados"}, 1
        },
        {
            "Qual e a base numerica do sistema hexadecimal?",
            {"2", "8", "10", "16"}, 3
        },
        {
            "O que significa SQL?",
            {"Linguagem de Consulta Simples",
             "Linguagem de Consulta Estruturada",
             "Sistema de Consulta Logica",
             "Suporte de Qualidade Logica"}, 1
        },
        {
            "Qual funcao em C aloca memoria dinamicamente?",
            {"alloc()", "malloc()", "memalloc()", "new()"}, 1
        },
        {
            "O que e recursao em programacao?",
            {"Loop infinito",
             "Funcao que chama a si mesma",
             "Tipo de variavel global",
             "Estrutura de dados linear"}, 1
        },
        {
            "Qual e a complexidade do algoritmo de busca binaria?",
            {"O(n)", "O(n^2)", "O(log n)", "O(1)"}, 2
        },
        {
            "O que e um sistema operacional?",
            {"Programa antivirus",
             "Hardware de armazenamento",
             "Software que gerencia recursos do computador",
             "Linguagem de programacao de baixo nivel"}, 2
        }
    };

    // Embaralha o banco de questoes (Fisher-Yates)
    for (int i = TOTAL_QUESTOES - 1; i > 0; i--) {
        int j = rand() % (i + 1);
        struct Pergunta tmp = banco[i];
        banco[i] = banco[j];
        banco[j] = tmp;
    }

    int pontos = 0;
    printf(AMARELO "\n=== QUIZ DE ENGENHARIA ===\n" RESET);
    printf("Respondendo %d perguntas sorteadas (banco de %d).\n",
           QUESTOES_POR_RODADA, TOTAL_QUESTOES);

    for (int i = 0; i < QUESTOES_POR_RODADA; i++) {
        struct Pergunta *q = &banco[i];

        // Salva a resposta correta antes de embaralhar as opcoes
        char correta[80];
        copiar_string(correta, q->opcoes[q->resposta_correta]);

        // Embaralha as opcoes (Fisher-Yates)
        for (int k = 3; k > 0; k--) {
            int m = rand() % (k + 1);
            char tmp[80];
            copiar_string(tmp,          q->opcoes[k]);
            copiar_string(q->opcoes[k], q->opcoes[m]);
            copiar_string(q->opcoes[m], tmp);
        }

        // Atualiza indice da resposta correta apos embaralhamento
        for (int k = 0; k < 4; k++) {
            if (comparar_strings(q->opcoes[k], correta)) {
                q->resposta_correta = k;
                break;
            }
        }

        printf(AZUL "\nPergunta %d/%d:" RESET " %s\n",
               i + 1, QUESTOES_POR_RODADA, q->pergunta);
        for (int j = 0; j < 4; j++) {
            printf("  %d) %s\n", j + 1, q->opcoes[j]);
        }

        printf("Sua resposta (1-4): ");
        int resposta = ler_inteiro(1, 4);

        if (resposta - 1 == q->resposta_correta) {
            printf(VERDE "Resposta correta!\n" RESET);
            pontos++;
        } else {
            printf(VERMELHO "Errado! A resposta certa e: %d) %s\n" RESET,
                   q->resposta_correta + 1,
                   q->opcoes[q->resposta_correta]);
        }
    }

    printf(AMARELO "\nSua pontuacao final: %d/%d\n" RESET, pontos, QUESTOES_POR_RODADA);

    if      (pontos == QUESTOES_POR_RODADA)     printf(VERDE    "Excelente! Pontuacao perfeita!\n" RESET);
    else if (pontos >= QUESTOES_POR_RODADA / 2) printf(VERDE    "Bom trabalho!\n" RESET);
    else                                         printf(VERMELHO "Continue estudando!\n" RESET);
}

// ============================================================
// Roletao de Caixas
// ============================================================

void roleta_caixas() {
    const char jogadores[7][20] = {"John", "Mary", "Carl", "Anna", "Peter", "Sophie", "Mike"};

    printf(AMARELO "\n=== ROLETAO DE CAIXAS ===\n" RESET);

    printf("\nEscolha o Jogador 1:\n");
    for (int i = 0; i < 7; i++) printf("  %d. %s\n", i + 1, jogadores[i]);
    printf("Jogador 1 (1-7): ");
    int jogador1 = ler_inteiro(1, 7);

    printf("\nEscolha o Jogador 2:\n");
    for (int i = 0; i < 7; i++) printf("  %d. %s\n", i + 1, jogadores[i]);
    printf("Jogador 2 (1-7): ");
    int jogador2 = ler_inteiro(1, 7);

    // Sorteio aleatorio com rand()
    int premio = rand() % 5 + 1;
    int perigo;
    do {
        perigo = rand() % 5 + 1;
    } while (perigo == premio);

    int vez = rand() % 2;
    printf(VERDE "\n%s comeca!\n" RESET, jogadores[vez ? jogador2 - 1 : jogador1 - 1]);

    int abertas[5] = {0};

    while (1) {
        const char *nome_atual = jogadores[vez ? jogador2 - 1 : jogador1 - 1];

        printf("\nCaixas: ");
        for (int i = 1; i <= 5; i++) {
            if (abertas[i - 1]) printf(VERMELHO "[%d:X] " RESET, i);
            else                 printf(VERDE   "[%d]   " RESET, i);
        }
        printf("\n");

        printf("%s, escolha uma caixa (1-5): ", nome_atual);
        int escolha = ler_inteiro(1, 5);

        if (abertas[escolha - 1]) {
            printf(VERMELHO "Essa caixa ja foi aberta! Escolha outra.\n" RESET);
            continue;
        }

        abertas[escolha - 1] = 1;

        if (escolha == premio) {
            printf(VERDE "PARABENS, %s! Voce encontrou o premio!\n" RESET, nome_atual);
            break;
        } else if (escolha == perigo) {
            printf(VERMELHO "PERDEU, %s! Caixa amaldicada!\n" RESET, nome_atual);
            break;
        } else {
            printf("Caixa vazia. Vez do proximo jogador!\n");
            vez = !vez;
        }
    }
}

// ============================================================
// Batalha de Cavaleiros
// ============================================================

void batalha_cavaleiros() {
    typedef struct {
        char nome[20];
        int  cavaleiros[2];
    } Jogador;

    printf(AMARELO "\n=== BATALHA DE CAVALEIROS ===\n" RESET);

    Jogador j1, j2;

    printf("Nome do Jogador 1: ");
    fgets(j1.nome, sizeof(j1.nome), stdin);
    j1.nome[contar_caracteres(j1.nome) - 1] = '\0';

    printf("Nome do Jogador 2: ");
    fgets(j2.nome, sizeof(j2.nome), stdin);
    j2.nome[contar_caracteres(j2.nome) - 1] = '\0';

    j1.cavaleiros[0] = j1.cavaleiros[1] = 10;
    j2.cavaleiros[0] = j2.cavaleiros[1] = 10;

    int turno = rand() % 2;
    printf(VERDE "\n%s comeca a batalha!\n" RESET, turno ? j2.nome : j1.nome);

    while (1) {
        Jogador *atual    = turno ? &j2 : &j1;
        Jogador *oponente = turno ? &j1 : &j2;

        printf(AZUL "\n--- Turno de %s ---\n" RESET, atual->nome);
        printf("  Seus cavaleiros    : [1] %d aura | [2] %d aura\n",
               atual->cavaleiros[0], atual->cavaleiros[1]);
        printf("  Cavaleiros inimigos: [1] %d aura | [2] %d aura\n",
               oponente->cavaleiros[0], oponente->cavaleiros[1]);

        printf("\n  1. Atacar\n  2. Transferir aura\n  3. Meditar\n");
        printf("Escolha (1-3): ");
        int acao = ler_inteiro(1, 3);

        if (acao == 1) {
            printf("Cavaleiro atacante (1-2): ");
            int atacante = ler_inteiro(1, 2);
            printf("Cavaleiro defensor (1-2): ");
            int defensor = ler_inteiro(1, 2);

            if (atual->cavaleiros[atacante - 1] <= 0) {
                printf(VERMELHO "Esse cavaleiro foi derrotado e nao pode atacar!\n" RESET);
            } else {
                int dano = rand() % 5 + 2; // dano aleatorio entre 2 e 6
                oponente->cavaleiros[defensor - 1] -= dano;
                printf(VERMELHO "%d de dano causado ao cavaleiro %d de %s!\n" RESET,
                       dano, defensor, oponente->nome);

                if (oponente->cavaleiros[defensor - 1] <= 0) {
                    oponente->cavaleiros[defensor - 1] = 0;
                    printf(VERMELHO "Cavaleiro %d de %s foi derrotado!\n" RESET,
                           defensor, oponente->nome);
                }
            }

        } else if (acao == 2) {
            printf("Transferir de (1-2): ");
            int origem = ler_inteiro(1, 2);
            printf("Para (1-2): ");
            int destino = ler_inteiro(1, 2);

            if (origem == destino) {
                printf(VERMELHO "Origem e destino nao podem ser o mesmo cavaleiro!\n" RESET);
            } else if (atual->cavaleiros[origem - 1] <= 1) {
                printf(VERMELHO "Aura insuficiente para transferir!\n" RESET);
            } else {
                int quantidade = atual->cavaleiros[origem - 1] / 2;
                atual->cavaleiros[origem - 1] -= quantidade;
                atual->cavaleiros[destino - 1] += quantidade;
                printf(VERDE "%d de aura transferida do cavaleiro %d para o cavaleiro %d!\n" RESET,
                       quantidade, origem, destino);
            }

        } else if (acao == 3) {
            printf("Cavaleiro para meditar (1-2): ");
            int cavaleiro = ler_inteiro(1, 2);

            int recuperacao = rand() % 4 + 3; // recuperacao aleatoria entre 3 e 6
            atual->cavaleiros[cavaleiro - 1] += recuperacao;
            printf(AMARELO "Cavaleiro %d recuperou %d de aura!\n" RESET,
                   cavaleiro, recuperacao);
        }

        if (oponente->cavaleiros[0] <= 0 && oponente->cavaleiros[1] <= 0) {
            printf(VERDE "\n*** %s VENCEU A BATALHA! ***\n" RESET, atual->nome);
            break;
        }

        turno = !turno;
    }
}

